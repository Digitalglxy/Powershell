# Liste de commandes utiles dans Powershell

# Eviter les restrictions pour le lancement de scripts
Set-ExecutionPolicy -Scope Process -ExecutionPolicy Bypass

# convertir un .ps1 en .exe avec ps2exe
Install-Module -Name PS2EXE -Force -Scope CurrentUser -AllowClobber

=> puis importer le module :
Import-Module PS2EXE -Force

==> ensuite lancer la commande de complation, exemple :
Invoke-PS2EXE -InputFile "C:\Users\John\Documents\SCRIPTS\PS1\MDP_GENERATOR_(v1.0).ps1" -OutputFile "C:\Users\John\Documents\SCRIPTS\PS1\MDP_GENERATOR_(v1.0).exe" -NoConsole -NoAdmin


## liste les services actifs ou non dans une grille (gridview)
gsv | ogv
====ou====
Get-Service | Out-GridView
#gsv = Get-Service
#ogv = Out-GridView

## obtenir la version de Powershell
$PSVersionTable
====ou===
$Host.version.major

## information sur une commande
GET-HELP

## En ajoutant éventuellement les commutateurs : “-Example” ou “-Full” ou “-Detailed” ou “-online” 
GET-HELP -Exemple

## lister les modules 
Get-Command –CommandType cmdlet | group verb | sort count –Descending

## Voir la clé OEM d'un poste
wmic path softwarelicensingservice get OA3xOriginalProductKey

## Connaitre les groupes AD d'un utilisateur
get-adprincipalgroupmembership admin.jsicot | select name | Out-Gridview

